rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidHotel(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.image is string && data.image.size() <= 2000 &&
             data.address is string && data.address.size() <= 500 &&
             data.cityId is string && data.cityId.size() <= 100 &&
             data.ownerName is string && data.ownerName.size() <= 200 &&
             data.ownerPhone is string && data.ownerPhone.size() <= 50 &&
             (!('createdAt' in data) || data.createdAt == request.time);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Hotels collection
    match /hotels/{hotelId} {
      // Anyone (public/signed in/guest) can view hotels
      allow read: if true;
      
      // For this demo, we allow creation if signed in or dynamic guest seeding, under schema validations.
      allow create: if isValidHotel(request.resource.data);
      
      // Disable update/delete on public catalog for security
      allow update, delete: if false;
    }
  }
}
