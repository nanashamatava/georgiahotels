rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidHotel(data) {
      return data.name is string && data.name.size() > 0 &&
             data.image is string &&
             data.address is string &&
             data.cityId is string &&
             data.ownerName is string &&
             data.ownerPhone is string;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Hotels collection
    match /hotels/{hotelId} {
      // Anyone signed in can view hotels
      allow read: if isSignedIn();
      
      // For this demo, we allow creation if signed in, but in a real app,
      // you'd probably restrict this to specific roles/admins.
      allow create: if isSignedIn() && isValidHotel(request.resource.data);
      
      // Updates and deletes are restricted (could be owner of the hotel or admin)
      // For simplicity in this prompt, let's just allow reading for now as it's a booking site.
      // If we had a 'creatorId' field, we would use it.
    }
  }
}
